---
const base = import.meta.env.BASE_URL;
const CATS = [
  {
    id: "premiers-pas",
    title: "Premiers Pas",
    range: "0 → 3 ans",
    sizes: "19 → 27",
    tag: "Bébés",
    hint: "le tout premier pas",
    cover: `${base}chaussures/premiers-pas/premiers-pas-1.webp`,
    images: [
      `${base}chaussures/premiers-pas/premiers-pas-1.webp`,
      `${base}chaussures/premiers-pas/premiers-pas-2.webp`,
      `${base}chaussures/premiers-pas/premiers-pas-3.webp`,
      `${base}chaussures/premiers-pas/premiers-pas-4.webp`,
      `${base}chaussures/premiers-pas/premiers-pas-5.webp`,
      `${base}chaussures/premiers-pas/premiers-pas-6.webp`,
    ],
  },
  {
    id: "juniors",
    title: "Juniors",
    range: "3 → 10 ans",
    sizes: "28 → 34",
    tag: "Enfants",
    hint: "école & aventures",
    cover: `${base}chaussures/junior/junior-1.webp`,
    images: [
      `${base}chaussures/junior/junior-1.webp`,
      `${base}chaussures/junior/junior-2.webp`,
      `${base}chaussures/junior/junior-3.webp`,
      `${base}chaussures/junior/junior-4.webp`,
      `${base}chaussures/junior/junior-5.webp`,
      `${base}chaussures/junior/junior-6.webp`,
      `${base}chaussures/junior/junior-7.webp`,
      `${base}chaussures/junior/junior-8.webp`,
    ],
  },
  {
    id: "ados",
    title: "Ados",
    range: "10 → 16 ans",
    sizes: "35 → 40",
    tag: "Ados",
    hint: "style à eux",
    cover: `${base}chaussures/ado/ado-1.webp`,
    images: [
      `${base}chaussures/ado/ado-1.webp`,
      `${base}chaussures/ado/ado-2.webp`,
      `${base}chaussures/ado/ado-3.webp`,
      `${base}chaussures/ado/ado-4.webp`,
      `${base}chaussures/ado/ado-5.webp`,
    ],
  },
];

const allImages = CATS.map(c => c.images);
---

<section id="categories" style="background:var(--bg-alt);">
  <div class="container">

    <div class="s-head reveal">
      <div>
        <span class="eyebrow">Pour qui ?</span>
        <h2 style="margin-top:14px;">
          Du premier pas <br/>
          <em style="font-style:italic;color:var(--ink-soft);">au lycée.</em>
        </h2>
      </div>
      <p class="s-intro">
        Trois âges, trois rayons — toujours du 19 au 40. On prend le temps de mesurer,
        d'essayer, de trouver la bonne paire.
      </p>
    </div>

    <!-- Grille cat-cards -->
    <div class="cats">
      {CATS.map((c, ci) => (
        <button
          class="cat-card reveal"
          data-d={String(ci + 1)}
          data-cat={ci}
          aria-label={`Voir les photos ${c.title}`}
        >
          <img src={c.cover} alt={c.title} loading={ci === 0 ? 'eager' : 'lazy'} />
          <span class="age-tag">{c.tag} · {c.sizes}</span>
          <div class="cat-mask"></div>
          <div class="cat-meta">
            <div>
              <span class="range">— {c.hint}</span>
              <h3>{c.title}</h3>
              <div style="font-family:var(--font-body);font-size:14px;opacity:.8;margin-top:6px;">{c.range}</div>
            </div>
            <div class="cat-arrow" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14"/><path d="m13 5 7 7-7 7"/>
              </svg>
            </div>
          </div>
        </button>
      ))}
    </div>

    <!-- Strip types -->
    <div class="types-strip reveal" data-d="4">
      <span class="types-lead"><span class="hand">Aussi chez nous —</span></span>

      <a href="#boutique" class="type-card type-card--chaussons">
        <div class="type-ic">
          <img src={`${base}icons/slippers.png`} alt="" width="38" height="38" />
        </div>
        <div class="type-body">
          <h4>Chaussons</h4>
          <p>Bellamy, du 19 au 35 — pour la maison et la crèche.</p>
        </div>
        <span class="type-arrow" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"/><path d="m13 5 7 7-7 7"/>
          </svg>
        </span>
      </a>

      <a href="#boutique" class="type-card type-card--bottes">
        <div class="type-ic">
          <img src={`${base}icons/rain-boots.png`} alt="" width="38" height="38" />
        </div>
        <div class="type-body">
          <h4>Bottes caoutchouc</h4>
          <p>Pour les flaques bretonnes — du 22 au 38.</p>
        </div>
        <span class="type-arrow" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"/><path d="m13 5 7 7-7 7"/>
          </svg>
        </span>
      </a>
    </div>

  </div>
</section>

<!-- Lightbox -->
<div class="lb" id="lb" role="dialog" aria-modal="true" aria-label="Visionneuse" hidden>
  <div class="lb-backdrop" id="lb-backdrop"></div>

  <div class="lb-inner">
    <!-- Header -->
    <div class="lb-header">
      <div class="lb-count"><span id="lb-cur">1</span> / <span id="lb-tot">1</span></div>
      <button class="lb-close" id="lb-close" aria-label="Fermer">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 6 6 18M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- Image -->
    <div class="lb-stage">
      <button class="lb-arrow lb-prev" id="lb-prev" aria-label="Photo précédente">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 12H5"/><path d="m11 18-6-6 6-6"/>
        </svg>
      </button>
      <div class="lb-img-wrap">
        <img class="lb-img" id="lb-img" src="" alt="" />
      </div>
      <button class="lb-arrow lb-next" id="lb-next" aria-label="Photo suivante">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14"/><path d="m13 6 6 6-6 6"/>
        </svg>
      </button>
    </div>

    <!-- Miniatures -->
    <div class="lb-thumbs" id="lb-thumbs"></div>
  </div>
</div>

<style>
/* ---- cat-card as button — reset only what's needed ---- */
.cat-card {
  border: none;
  padding: 0;
  margin: 0;
  font: inherit;
  cursor: pointer;
  text-align: left;
  -webkit-appearance: none;
  appearance: none;
}
.cat-card:focus-visible {
  outline: 3px solid var(--accent);
  outline-offset: 4px;
  border-radius: var(--radius-lg);
}


/* ---- Lightbox ---- */
.lb {
  position: fixed;
  inset: 0;
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
}
.lb[hidden] { display: none; }

.lb-backdrop {
  position: absolute;
  inset: 0;
  background: color-mix(in oklab, var(--ink) 88%, transparent);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}

.lb-inner {
  position: relative;
  z-index: 1;
  width: min(94vw, 780px);
  display: flex;
  flex-direction: column;
  gap: 14px;
  margin-top: 80px;
  animation: lb-in .28s cubic-bezier(.2,.8,.2,1);
}

@keyframes lb-in {
  from { opacity: 0; transform: scale(.93) translateY(12px); }
  to   { opacity: 1; transform: none; }
}

/* header */
.lb-header {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 16px;
  color: var(--bg);
}
.lb-count {
  font-size: 13px;
  letter-spacing: .08em;
  opacity: .7;
  font-variant-numeric: tabular-nums;
}
.lb-close {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  border: 1.5px solid color-mix(in oklab, var(--bg) 35%, transparent);
  background: color-mix(in oklab, var(--bg) 12%, transparent);
  color: var(--bg);
  display: grid;
  place-items: center;
  cursor: pointer;
  transition: background var(--t-fast), border-color var(--t-fast);
}
.lb-close:hover {
  background: color-mix(in oklab, var(--bg) 22%, transparent);
  border-color: var(--bg);
}

/* stage */
.lb-stage {
  display: flex;
  align-items: center;
  gap: 12px;
}

.lb-img-wrap {
  flex: 1;
  border-radius: var(--radius-lg);
  overflow: hidden;
  background: var(--ink);
  aspect-ratio: 3/4;
  max-height: 68vh;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 32px 80px -24px rgba(0,0,0,.5);
}

.lb-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: opacity .25s;
}
.lb-img.loading { opacity: 0; }

.lb-arrow {
  flex: none;
  width: 48px;
  height: 48px;
  border-radius: 50%;
  border: 2px solid color-mix(in oklab, var(--bg) 35%, transparent);
  background: color-mix(in oklab, var(--bg) 10%, transparent);
  color: var(--bg);
  display: grid;
  place-items: center;
  cursor: pointer;
  transition: background var(--t-fast), border-color var(--t-fast), transform var(--t-fast);
}
.lb-arrow:hover {
  background: color-mix(in oklab, var(--bg) 22%, transparent);
  border-color: var(--bg);
  transform: scale(1.08);
}
.lb-arrow:disabled { opacity: .25; cursor: default; transform: none; }

/* thumbs */
.lb-thumbs {
  display: flex;
  gap: 8px;
  overflow-x: auto;
  padding-bottom: 2px;
  scrollbar-width: thin;
  scrollbar-color: color-mix(in oklab, var(--bg) 25%, transparent) transparent;
}
.lb-thumb {
  flex: none;
  width: 60px;
  height: 60px;
  border-radius: 8px;
  overflow: hidden;
  border: 2px solid transparent;
  background: none;
  padding: 0;
  cursor: pointer;
  opacity: .55;
  transition: opacity var(--t-fast), border-color var(--t-fast), transform var(--t-fast);
}
.lb-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
.lb-thumb:hover { opacity: .85; transform: translateY(-2px); }
.lb-thumb.active { opacity: 1; border-color: var(--accent-2); }

@media (max-width: 600px) {
  .lb-arrow { display: none; }
  .lb-img-wrap { aspect-ratio: 3/4; max-height: 60vh; }
  .lb-thumb { width: 48px; height: 48px; }
}
</style>

<script define:vars={{ allImages, catTitles: CATS.map(c => c.title) }}>
  const lb       = document.getElementById('lb');
  const lbImg    = document.getElementById('lb-img');
  const lbCur    = document.getElementById('lb-cur');
  const lbTot    = document.getElementById('lb-tot');
  const lbThumbs = document.getElementById('lb-thumbs');
  const lbPrev   = document.getElementById('lb-prev');
  const lbNext   = document.getElementById('lb-next');
  const lbClose  = document.getElementById('lb-close');
  const lbBack   = document.getElementById('lb-backdrop');
  let images = [];
  let idx    = 0;

  function open(catIdx, startIdx = 0) {
    images = allImages[catIdx];
    lbTot.textContent = images.length;

    buildThumbs(startIdx);
    lb.hidden = false;
    document.body.style.overflow = 'hidden';
    lbClose.focus();
    goTo(startIdx, true);
  }

  function buildThumbs(activeIdx) {
    lbThumbs.innerHTML = '';
    images.forEach((src, i) => {
      const btn = document.createElement('button');
      btn.className = 'lb-thumb' + (i === activeIdx ? ' active' : '');
      btn.setAttribute('aria-label', `Photo ${i + 1}`);
      const img = document.createElement('img');
      img.src = src; img.alt = ''; img.loading = 'lazy';
      btn.appendChild(img);
      btn.addEventListener('click', () => goTo(i));
      lbThumbs.appendChild(btn);
    });
  }

  function close() {
    lb.hidden = true;
    document.body.style.overflow = '';
  }

  function goTo(i, instant = false) {
    idx = i;
    lbCur.textContent = i + 1;

    if (!instant) lbImg.classList.add('loading');
    const newImg = new Image();
    newImg.src = images[i];
    newImg.onload = () => {
      lbImg.src = images[i];
      lbImg.alt = `Photo ${i + 1}`;
      lbImg.classList.remove('loading');
    };
    if (instant || newImg.complete) {
      lbImg.src = images[i];
      lbImg.classList.remove('loading');
    }

    lbPrev.disabled = i === 0;
    lbNext.disabled = i === images.length - 1;

    // Sync thumbs
    lbThumbs.querySelectorAll('.lb-thumb').forEach((t, ti) => {
      t.classList.toggle('active', ti === i);
    });
    const activeThumb = lbThumbs.children[i];
    if (activeThumb) activeThumb.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
  }

  // Open via cat-cards
  document.querySelectorAll('.cat-card').forEach(card => {
    card.addEventListener('click', () => open(Number(card.dataset.cat)));
  });

  lbPrev.addEventListener('click', () => { if (idx > 0) goTo(idx - 1); });
  lbNext.addEventListener('click', () => { if (idx < images.length - 1) goTo(idx + 1); });
  lbClose.addEventListener('click', close);
  lbBack.addEventListener('click', close);

  // Keyboard
  document.addEventListener('keydown', e => {
    if (lb.hidden) return;
    if (e.key === 'Escape')     close();
    if (e.key === 'ArrowLeft')  { if (idx > 0) goTo(idx - 1); }
    if (e.key === 'ArrowRight') { if (idx < images.length - 1) goTo(idx + 1); }
  });

  // Swipe
  let startX = 0;
  lb.addEventListener('touchstart', e => { startX = e.touches[0].clientX; }, { passive: true });
  lb.addEventListener('touchend', e => {
    const dx = e.changedTouches[0].clientX - startX;
    if (Math.abs(dx) < 40) return;
    if (dx < 0 && idx < images.length - 1) goTo(idx + 1);
    if (dx > 0 && idx > 0) goTo(idx - 1);
  });
</script>
