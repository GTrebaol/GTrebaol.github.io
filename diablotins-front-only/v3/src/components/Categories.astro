---
const CATS = [
  {
    id: "premiers-pas",
    title: "Premiers Pas",
    range: "0 → 3 ans",
    sizes: "19 → 27",
    images: [
      { src: "/chaussures/premiers-pas/premiers-pas-1.webp", alt: "Premiers pas 1" },
      { src: "/chaussures/premiers-pas/premiers-pas-2.webp", alt: "Premiers pas 2" },
      { src: "/chaussures/premiers-pas/premiers-pas-3.webp", alt: "Premiers pas 3" },
      { src: "/chaussures/premiers-pas/premiers-pas-4.webp", alt: "Premiers pas 4" },
      { src: "/chaussures/premiers-pas/premiers-pas-5.webp", alt: "Premiers pas 5" },
      { src: "/chaussures/premiers-pas/premiers-pas-6.webp", alt: "Premiers pas 6" },
    ],
  },
  {
    id: "juniors",
    title: "Juniors",
    range: "3 → 10 ans",
    sizes: "28 → 34",
    images: [
      { src: "/chaussures/junior/junior-1.webp", alt: "Juniors 1" },
      { src: "/chaussures/junior/junior-2.webp", alt: "Juniors 2" },
      { src: "/chaussures/junior/junior-3.webp", alt: "Juniors 3" },
      { src: "/chaussures/junior/junior-4.webp", alt: "Juniors 4" },
      { src: "/chaussures/junior/junior-5.webp", alt: "Juniors 5" },
      { src: "/chaussures/junior/junior-6.webp", alt: "Juniors 6" },
      { src: "/chaussures/junior/junior-7.webp", alt: "Juniors 7" },
      { src: "/chaussures/junior/junior-8.webp", alt: "Juniors 8" },
    ],
  },
  {
    id: "ados",
    title: "Ados",
    range: "10 → 16 ans",
    sizes: "35 → 40",
    images: [
      { src: "/chaussures/ado/ado-1.webp", alt: "Ados 1" },
      { src: "/chaussures/ado/ado-2.webp", alt: "Ados 2" },
      { src: "/chaussures/ado/ado-3.webp", alt: "Ados 3" },
      { src: "/chaussures/ado/ado-4.webp", alt: "Ados 4" },
      { src: "/chaussures/ado/ado-5.webp", alt: "Ados 5" },
    ],
  },
];
---

<section id="categories" style="background:var(--bg-alt);">
  <div class="container">

    <div class="s-head reveal">
      <div>
        <span class="eyebrow">Pour qui ?</span>
        <h2 style="margin-top:14px;">
          Du premier pas <br/>
          <em style="font-style:italic;color:var(--ink-soft);">au lycée.</em>
        </h2>
      </div>
      <p class="s-intro">
        Trois âges, trois rayons — toujours du 19 au 40. On prend le temps de mesurer,
        d'essayer, de trouver la bonne paire.
      </p>
    </div>

    <!-- Visionneuse -->
    <div class="viewer reveal" data-d="2" id="viewer">

      <!-- Onglets -->
      <div class="viewer-tabs" role="tablist">
        {CATS.map((cat, ci) => (
          <button
            class={`vtab${ci === 0 ? ' active' : ''}`}
            role="tab"
            aria-selected={ci === 0 ? 'true' : 'false'}
            aria-controls={`vpanel-${ci}`}
            data-cat={ci}
            id={`vtab-${ci}`}
          >
            <span class="vtab-title">{cat.title}</span>
            <span class="vtab-range">{cat.sizes}</span>
          </button>
        ))}
      </div>

      <!-- Panneaux -->
      {CATS.map((cat, ci) => (
        <div
          class={`vpanel${ci === 0 ? ' active' : ''}`}
          id={`vpanel-${ci}`}
          role="tabpanel"
          aria-labelledby={`vtab-${ci}`}
          data-panel={ci}
        >
          <!-- Image principale -->
          <div class="vimg-wrap">
            <button class="varrow varrow--prev" data-dir="-1" aria-label="Photo précédente">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M19 12H5"/><path d="m11 18-6-6 6-6"/>
              </svg>
            </button>

            <div class="vslides">
              {cat.images.map((img, ii) => (
                <div class={`vslide${ii === 0 ? ' active' : ''}`} data-slide={ii}>
                  <img src={img.src} alt={img.alt} loading={ci === 0 && ii === 0 ? 'eager' : 'lazy'} />
                </div>
              ))}
            </div>

            <button class="varrow varrow--next" data-dir="1" aria-label="Photo suivante">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14"/><path d="m13 6 6 6-6 6"/>
              </svg>
            </button>

            <!-- Compteur -->
            <div class="vcount">
              <span class="vcount-cur">1</span>/<span class="vcount-tot">{cat.images.length}</span>
            </div>
          </div>

          <!-- Miniatures -->
          <div class="vthumbs">
            {cat.images.map((img, ii) => (
              <button
                class={`vthumb${ii === 0 ? ' active' : ''}`}
                data-slide={ii}
                aria-label={`Photo ${ii + 1}`}
              >
                <img src={img.src} alt="" loading="lazy" />
              </button>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Strip types -->
    <div class="types-strip reveal" data-d="3">
      <span class="types-lead"><span class="hand">Aussi chez nous —</span></span>

      <a href="#boutique" class="type-card type-card--chaussons">
        <div class="type-ic">
          <img src="/icons/slippers.png" alt="" width="38" height="38" />
        </div>
        <div class="type-body">
          <h4>Chaussons</h4>
          <p>Bellamy, du 19 au 35 — pour la maison et la crèche.</p>
        </div>
        <span class="type-arrow" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"/><path d="m13 5 7 7-7 7"/>
          </svg>
        </span>
      </a>

      <a href="#boutique" class="type-card type-card--bottes">
        <div class="type-ic">
          <img src="/icons/rain-boots.png" alt="" width="38" height="38" />
        </div>
        <div class="type-body">
          <h4>Bottes caoutchouc</h4>
          <p>Pour les flaques bretonnes — du 22 au 38.</p>
        </div>
        <span class="type-arrow" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"/><path d="m13 5 7 7-7 7"/>
          </svg>
        </span>
      </a>
    </div>

  </div>
</section>

<style>
/* ---- Viewer ---- */
.viewer {
  margin-bottom: clamp(36px, 5vw, 64px);
}

.viewer-tabs {
  display: flex;
  gap: 10px;
  margin-bottom: 24px;
  flex-wrap: wrap;
}

.vtab {
  display: flex;
  flex-direction: column;
  gap: 2px;
  padding: 12px 22px;
  border-radius: var(--radius-pill);
  border: 2px solid var(--line);
  background: var(--paper);
  color: var(--ink-soft);
  cursor: pointer;
  transition: border-color var(--t-fast), background var(--t-fast), color var(--t-fast), box-shadow var(--t-fast);
  text-align: left;
}
.vtab:hover {
  border-color: var(--ink);
  color: var(--ink);
}
.vtab.active {
  background: var(--ink);
  border-color: var(--ink);
  color: var(--bg);
  box-shadow: 3px 3px 0 var(--accent);
}
.vtab-title {
  font-family: var(--font-display);
  font-size: 18px;
  line-height: 1;
}
.vtab-range {
  font-size: 11px;
  letter-spacing: .12em;
  text-transform: uppercase;
  opacity: .7;
}

/* ---- Panel ---- */
.vpanel { display: none; }
.vpanel.active { display: block; }

/* ---- Image principale ---- */
.vimg-wrap {
  position: relative;
  border-radius: var(--radius-lg);
  overflow: hidden;
  background: var(--paper);
  aspect-ratio: 4/3;
  max-height: 540px;
  box-shadow: 0 20px 60px -24px rgba(31,26,23,.22);
}

@media (max-width: 600px) {
  .vimg-wrap { aspect-ratio: 3/4; max-height: none; }
}

.vslides {
  position: relative;
  width: 100%;
  height: 100%;
}

.vslide {
  position: absolute;
  inset: 0;
  opacity: 0;
  transition: opacity .45s cubic-bezier(.4,0,.2,1);
}
.vslide.active { opacity: 1; }
.vslide img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* ---- Flèches ---- */
.varrow {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 10;
  width: 48px;
  height: 48px;
  border-radius: 50%;
  border: 2px solid var(--ink);
  background: var(--paper);
  color: var(--ink);
  display: grid;
  place-items: center;
  cursor: pointer;
  transition: background var(--t-fast), color var(--t-fast), transform var(--t-fast), box-shadow var(--t-fast);
  box-shadow: 3px 3px 0 var(--ink);
}
.varrow--prev { left: 16px; }
.varrow--next { right: 16px; }
.varrow:hover {
  background: var(--ink);
  color: var(--bg);
  transform: translateY(calc(-50% - 2px));
  box-shadow: 4px 5px 0 var(--accent);
}
.varrow:active {
  transform: translateY(calc(-50% + 1px));
  box-shadow: 1px 2px 0 var(--ink);
}

/* ---- Compteur ---- */
.vcount {
  position: absolute;
  bottom: 14px;
  right: 18px;
  background: color-mix(in oklab, var(--ink) 72%, transparent);
  color: var(--bg);
  font-size: 13px;
  letter-spacing: .06em;
  padding: 5px 12px;
  border-radius: var(--radius-pill);
  font-family: var(--font-body);
  font-weight: 500;
}
.vcount-cur { font-weight: 700; }

/* ---- Miniatures ---- */
.vthumbs {
  display: flex;
  gap: 10px;
  margin-top: 14px;
  overflow-x: auto;
  padding-bottom: 4px;
  scrollbar-width: thin;
  scrollbar-color: var(--line) transparent;
}

.vthumb {
  flex: none;
  width: 72px;
  height: 72px;
  border-radius: 10px;
  overflow: hidden;
  border: 2.5px solid transparent;
  cursor: pointer;
  padding: 0;
  background: var(--paper);
  transition: border-color var(--t-fast), transform var(--t-fast), box-shadow var(--t-fast);
  box-shadow: 0 2px 8px -4px rgba(31,26,23,.18);
}
.vthumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.vthumb:hover {
  border-color: var(--ink);
  transform: translateY(-2px);
}
.vthumb.active {
  border-color: var(--accent);
  box-shadow: 0 0 0 1px var(--accent), 3px 3px 0 var(--accent);
}

@media (max-width: 540px) {
  .vthumb { width: 56px; height: 56px; }
  .vtab { padding: 10px 16px; }
}
</style>

<script>
  const viewer = document.getElementById('viewer');
  if (viewer) {
    const tabs = viewer.querySelectorAll('.vtab');
    const panels = viewer.querySelectorAll('.vpanel');

    function goToSlide(panel, idx) {
      const slides = panel.querySelectorAll('.vslide');
      const thumbs = panel.querySelectorAll('.vthumb');
      const cur = panel.querySelector('.vcount-cur');

      slides.forEach(s => s.classList.remove('active'));
      thumbs.forEach(t => t.classList.remove('active'));

      const slide = panel.querySelector(`.vslide[data-slide="${idx}"]`);
      const thumb = panel.querySelector(`.vthumb[data-slide="${idx}"]`);
      if (slide) slide.classList.add('active');
      if (thumb) {
        thumb.classList.add('active');
        thumb.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
      }
      if (cur) cur.textContent = String(idx + 1);
    }

    function activeSlideIdx(panel) {
      const active = panel.querySelector('.vslide.active');
      return active ? Number(active.dataset.slide) : 0;
    }

    function slideCount(panel) {
      return panel.querySelectorAll('.vslide').length;
    }

    tabs.forEach((tab, ci) => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => { t.classList.remove('active'); t.setAttribute('aria-selected', 'false'); });
        panels.forEach(p => p.classList.remove('active'));
        tab.classList.add('active');
        tab.setAttribute('aria-selected', 'true');
        const panel = panels[ci];
        panel.classList.add('active');
        goToSlide(panel, 0);
      });
    });

    panels.forEach(panel => {
      panel.querySelector('.varrow--prev')?.addEventListener('click', () => {
        const n = slideCount(panel);
        goToSlide(panel, (activeSlideIdx(panel) - 1 + n) % n);
      });
      panel.querySelector('.varrow--next')?.addEventListener('click', () => {
        const n = slideCount(panel);
        goToSlide(panel, (activeSlideIdx(panel) + 1) % n);
      });
      panel.querySelectorAll('.vthumb').forEach(thumb => {
        thumb.addEventListener('click', () => {
          goToSlide(panel, Number(thumb.dataset.slide));
        });
      });
    });

    // Swipe
    panels.forEach(panel => {
      const wrap = panel.querySelector('.vimg-wrap');
      if (!wrap) return;
      let startX = 0;
      wrap.addEventListener('touchstart', e => { startX = e.touches[0].clientX; }, { passive: true });
      wrap.addEventListener('touchend', e => {
        const dx = e.changedTouches[0].clientX - startX;
        if (Math.abs(dx) < 40) return;
        const n = slideCount(panel);
        goToSlide(panel, (activeSlideIdx(panel) + (dx < 0 ? 1 : -1) + n) % n);
      });
    });
  }
</script>
