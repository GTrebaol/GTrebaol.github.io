  </div>
  <div class="foot-bottom">
    <div>© 2026 Les Diablotins · Tous droits réservés</div>
    <div style="display:flex;gap:24px;">
      <span>Mentions légales</span>
      <span>Confidentialité</span>
    </div>
  </div>
</footer>
